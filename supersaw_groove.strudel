const bpm = 110
const scale = 4
setcps(bpm/60)

await samples('github:rudkx/samples')
$: sound("[bd [bd,stereoclap] bd [bd,stereoclap]]/4").gain(0.5).lpf(32000).room(0.5)._scope()
$: note("[0*3 <5*3> <0> <4 8*3 4*3 7>]/3").scale('C2:phrygian')
  .sound("supersaw").decay(tri.range(0.15,0.3).slow(2))
  .lpf(tri.range(1200,6000).slow(8)).lpq(tri.range(0,20).slow(7))
  .gain(0.5).room(0.5).color("orange").scope()
